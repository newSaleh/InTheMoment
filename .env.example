# Get this from @BotFather on Telegram after creating your bot.
BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# Where the SQLite database of subscribers is stored.
DB_PATH=bot_data.db

# Timezone used to decide "today" and the active reminder window.
TZ_NAME=Asia/Riyadh

# Reminders only fire between these hours (local to TZ_NAME), 0-23.
ACTIVE_HOUR_START=9
ACTIVE_HOUR_END=23

# How many random reminders each subscriber gets per day.
MIN_DAILY_REMINDERS=2
MAX_DAILY_REMINDERS=3

# Minimum minutes enforced between two reminders on the same day.
MIN_GAP_MINUTES=60

# Time of day (local to TZ_NAME) at which tomorrow's random schedule is drawn.
DAILY_RESCHEDULE_HOUR=0
DAILY_RESCHEDULE_MINUTE=5
